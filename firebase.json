{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "site": "jcash-wallet",
      "public": "out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        { "source": "**", "destination": "https://jcash-shadcn-preview.vercel.app", "type": 301 }
      ]
    },
    {
      "site": "jcash-wallet-000",
      "public": "out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        { "source": "**", "destination": "https://jcash-shadcn-preview.vercel.app", "type": 301 }
      ]
    }
  ]
}
